# API Configuration
# Port number for the backend server
PORT=your_port_number

# CORS - Allowed Origins (comma-separated for multiple domains)
# Example for development: http://localhost:3000
# Example for production: https://www.yourproject.com
ALLOW_ORIGINS=your_frontend_url_or_comma_separated_urls

# Database Configuration (PostgreSQL)
# For Docker: use host.docker.internal
# For EC2 Production: use RDS endpoint (e.g., lems-prod-db.xxxxxx.region.rds.amazonaws.com)
DATABASE_HOST=your_database_host
DATABASE_NAME=your_database_name
DATABASE_USERNAME=your_database_username
DATABASE_PASSWORD=your_secure_database_password
DATABASE_PORT=your_database_port

# Google OAuth 2.0 Configuration
# Get credentials from: https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID
# 2. Add authorized redirect URI matching GOOGLE_REDIRECT_URL below
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URL=your_backend_url/api/v1/auth/google/callback

# MinIO / AWS S3 Configuration
# For AWS S3: Create IAM user with S3 permissions (s3:GetObject, s3:PutObject, s3:DeleteObject)
# MINIO_USER = AWS Access Key ID
# MINIO_PASSWORD = AWS Secret Access Key
MINIO_USER=your_aws_access_key_id
MINIO_PASSWORD=your_aws_secret_access_key
MINIO_ENDPOINT=your_s3_endpoint_or_region.amazonaws.com
MINIO_USE_SSL=true_or_false
MINIO_BUCKET=your_s3_bucket_name
MINIO_REGION=your_aws_region

# PGAdmin Configuration (optional, for local development only)
PG_EMAIL=your_pgadmin_email
PG_PASSWORD=your_pgadmin_password

# JWT & Refresh Token Secrets
# Generate strong random strings (min 32 characters)
# Use: openssl rand -base64 32
JWT_SECRET=your_very_long_random_jwt_secret_min_32_chars
JWT_EXPIRATION_MINUTES=your_jwt_expiration_time_with_m_suffix
REFRESH_SECRET=your_very_long_random_refresh_secret_min_32_chars
REFRESH_EXPIRATION_HOURS=your_refresh_expiration_time_with_h_suffix
